---
const problems = [
  {
    num: "01",
    stat: 84,
    suffix: "%",
    label: "No Online Booking",
    description: "84% of electrician websites have no way to book online. Customers expect to schedule an appointment the same way they order food — instantly. No booking widget means they'll find one who has it.",
    severity: "critical",
  },
  {
    num: "02",
    stat: 70,
    suffix: "%",
    label: "No Service Area Pages",
    description: "70% of electrician sites have no service area pages. When someone searches \"electrician in [your city],\" you need a dedicated page to rank — your homepage alone won't cut it.",
    severity: "critical",
  },
  {
    num: "03",
    stat: 64,
    suffix: "%",
    label: "No After-Hours Capture",
    description: "64% of electrician websites have no way to capture leads after 6 PM. Electrical emergencies don't wait for business hours — and neither do the customers searching for help.",
    severity: "high",
  },
  {
    num: "04",
    stat: 60,
    suffix: "%",
    label: "No HTTPS Redirect",
    description: "60% of electrician sites don't redirect HTTP to HTTPS. Chrome shows a \"Not Secure\" warning that kills trust instantly — especially when you're asking to enter someone's home.",
    severity: "high",
  },
  {
    num: "05",
    stat: 56,
    suffix: "%",
    label: "No License Number",
    description: "56% of electrician sites don't display a license number. Electrical work requires licensing in most states — not showing yours makes you look less legitimate than competitors who do.",
    severity: "medium",
  },
  {
    num: "06",
    stat: 53,
    suffix: "%",
    label: "No Contact Form",
    description: "53% of electrician websites have no contact form. Not everyone wants to call. Many homeowners prefer to send a message, especially outside business hours.",
    severity: "medium",
  },
];

const severityColors: Record<string, string> = {
  critical: "bg-ink",
  high: "bg-ink-muted",
  medium: "bg-rule",
};
---

<section
  class="section-over-hero bg-surface-alt py-20 md:py-44 px-6 md:px-12 lg:px-16 relative border-t border-rule"
>
  <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 mb-16 md:mb-24">
    <div class="lg:w-1/3">
      <p data-reveal class="text-xs text-accent font-mono tracking-widest uppercase flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
        The Digital Bleeding
      </p>
    </div>
    <div class="lg:w-2/3">
      <h2
        data-reveal
        style="--delay: 100ms"
        class="text-3xl md:text-5xl lg:text-[3.5rem] font-bold leading-[0.95] tracking-tight"
      >
        We audited 1,200+ electrician websites.<br class="hidden md:block" />
        Here's what we <span class="text-accent">found.</span>
      </h2>
    </div>
  </div>

  <div class="space-y-0">
    {
      problems.map((problem, i) => (
        <div
          class="border-t border-rule py-8 md:py-10 group"
          data-reveal
          style={`--delay: ${i * 80}ms`}
        >
          <div class="flex flex-col md:flex-row md:items-start gap-6 md:gap-12">
            <div class="flex items-start gap-5 md:w-1/3 shrink-0">
              <!-- Severity bar -->
              <div class="flex flex-col items-center gap-3 pt-1">
                <span class="text-[10px] font-mono text-ink-muted">{problem.num}</span>
                <div class={`w-0.5 h-8 rounded-full ${severityColors[problem.severity]}`}></div>
              </div>
              <div>
                {problem.stat > 0 ? (
                  <span class="text-4xl md:text-5xl font-bold tracking-tight text-ink">
                    <span data-counter={problem.stat} data-suffix={problem.suffix}>0{problem.suffix}</span>
                  </span>
                ) : (
                  <span class="text-sm font-mono uppercase tracking-wider text-ink-muted">
                    Missing
                  </span>
                )}
                <span class="block text-sm font-medium text-ink mt-1">{problem.label}</span>
              </div>
            </div>
            <p class="text-ink-secondary text-base md:text-[1.0625rem] leading-relaxed md:w-2/3 max-w-xl">
              {problem.description}
            </p>
          </div>
        </div>
      ))
    }
    <div class="border-t border-rule" data-reveal-line style="--delay: 480ms"></div>
  </div>
</section>
